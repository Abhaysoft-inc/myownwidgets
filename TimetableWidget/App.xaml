<Application x:Class="TimetableWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TimetableWidget">
    <Application.Resources>
        <!-- Placeholder brushes; overwritten at startup by App.ApplyTheme() -->
        <SolidColorBrush x:Key="WidgetBg"
                Color="#1E1E2E"/>
        <SolidColorBrush x:Key="WidgetFg"
                Color="#E0E0F0"/>
        <SolidColorBrush x:Key="WidgetMuted"
                Color="#AAAACC"/>
        <SolidColorBrush x:Key="WidgetAccent"
                Color="#334488"/>
        <SolidColorBrush x:Key="WidgetTime"
                Color="#7799BB"/>
        <SolidColorBrush x:Key="WidgetPanel"
                Color="#22222E"/>
        <SolidColorBrush x:Key="WidgetInput"
                Color="#2A2A3E"/>
    </Application.Resources>
</Application>

