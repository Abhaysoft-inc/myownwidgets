<Window x:Class="TimetableWidget.AppearanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appearance"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <!-- Fixed dark shell so the editor is always readable -->
    <Border Background="#F2181828"
            CornerRadius="12"
            Padding="20">
        <StackPanel>

            <!-- Title bar -->
            <Grid Margin="0 0 0 18">
                <TextBlock Text="Appearance"
                           FontFamily="Segoe UI"
                        FontSize="15"
                        FontWeight="SemiBold"
                           Foreground="#E0E0F0"/>
                <Button Content="âœ•"
                        HorizontalAlignment="Right"
                        Width="26"
                        Height="26"
                        FontSize="11"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#88AAAACC"
                        Cursor="Hand"
                        Click="CancelBtn_Click"/>
            </Grid>

            <!-- Theme presets -->
            <TextBlock Text="THEME"
                       FontFamily="Segoe UI"
                    FontSize="10"
                    FontWeight="SemiBold"
                       Foreground="#55667788"
                       Margin="0 0 0 10"/>

            <WrapPanel x:Name="PresetPanel"
                    Margin="0 0 0 20"/>

            <!-- Opacity -->
            <TextBlock Text="WIDGET OPACITY"
                       FontFamily="Segoe UI"
                    FontSize="10"
                    FontWeight="SemiBold"
                       Foreground="#55667788"
                       Margin="0 0 0 8"/>
            <Grid Margin="0 0 0 22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="OpacitySlider"
                        Grid.Column="0"
                        Minimum="0.3"
                        Maximum="1.0"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="OpacitySlider_ValueChanged">
                    <Slider.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HotTrackBrushKey}"
                                Color="#334488"/>
                    </Slider.Resources>
                </Slider>
                <TextBlock x:Name="OpacityLabel"
                           Grid.Column="1"
                           FontFamily="Segoe UI"
                        FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Cancel"
                        Padding="0 10"
                        Background="#2A2A3E"
                        Foreground="#8888AA"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CancelBtn_Click"/>
                <Button Grid.Column="2"
                        Content="Apply"
                        Padding="0 10"
                        Background="#334488"
                        Foreground="#C0D8FF"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ApplyBtn_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>

