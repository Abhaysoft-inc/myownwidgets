<Window x:Class="TimetableWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timetable"
        SizeToContent="Height"
        Width="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <Border Background="{DynamicResource WidgetBg}"
            CornerRadius="10"
            Padding="14 12">
        <StackPanel>

            <!-- Header -->
            <TextBlock x:Name="DateText"
                       FontSize="11"
                       FontFamily="Segoe UI"
                       Foreground="{DynamicResource WidgetMuted}"
                       Margin="0 0 0 10"
                       TextWrapping="Wrap"/>

            <!-- Lecture rows -->
            <ItemsControl x:Name="LectureList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0 3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Time}"
                                       FontSize="10"
                                       FontFamily="Segoe UI"
                                       Foreground="{DynamicResource WidgetTime}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Subject}"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WidgetFg}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>