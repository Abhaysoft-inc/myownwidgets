<Window x:Class="CPContestWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CP Contest Widget"
        SizeToContent="Height"
        Width="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <Border Background="{DynamicResource WidgetBg}" CornerRadius="10" Padding="14 12">
        <StackPanel>
            <Grid Margin="0 0 0 10">
                <StackPanel>
                    <TextBlock Text="CP Contests"
                               FontSize="14"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource WidgetFg}"/>
                    <TextBlock x:Name="DateRangeText"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Foreground="{DynamicResource WidgetMuted}"
                               Margin="0 2 0 0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <ItemsControl x:Name="ContestList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource WidgetPanel}" CornerRadius="7" Padding="8" Margin="0 0 0 8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DayAndTime}"
                                               FontSize="10"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource WidgetTime}"
                                               VerticalAlignment="Top"
                                               TextWrapping="Wrap"
                                               Margin="0 0 8 0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Platform}"
                                               FontSize="10"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource WidgetMuted}"
                                               VerticalAlignment="Top"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding Name}"
                                           FontSize="12"
                                           FontFamily="Segoe UI"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WidgetFg}"
                                           TextWrapping="Wrap"
                                           Margin="0 6 0 0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
