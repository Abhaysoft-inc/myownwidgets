<Window x:Class="CodingPresence.AppearanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appearance — Coding Presence"
        Width="340"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground"
                    Value="#CDD6F4"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Margin"
                    Value="0,6,0,0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin"
                    Value="0,2,0,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="#CDD6F4"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Margin"
                    Value="0,6,0,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"
                    Value="#313244"/>
            <Setter Property="Foreground"
                    Value="#CDD6F4"/>
            <Setter Property="BorderBrush"
                    Value="#585B70"/>
            <Setter Property="Padding"
                    Value="12,5"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="18">
        <Label Content="CODING PRESENCE — APPEARANCE"
               FontSize="11"
               Foreground="#89B4FA"
               FontWeight="SemiBold"
               Margin="0,0,0,8"/>

        <Label Content="Opacity"/>
        <Slider x:Name="OpacitySlider"
                Minimum="0.2"
                Maximum="1.0"
                SmallChange="0.05"
                IsSnapToTickEnabled="False"
                ValueChanged="Slider_Changed"/>

        <Label Content="Width"/>
        <Slider x:Name="WidthSlider"
                Minimum="180"
                Maximum="500"
                SmallChange="1"
                IsSnapToTickEnabled="False"
                ValueChanged="Slider_Changed"/>

        <Label Content="Poll Interval (seconds)"/>
        <Slider x:Name="PollSlider"
                Minimum="1"
                Maximum="30"
                SmallChange="1"
                IsSnapToTickEnabled="True"
                TickFrequency="1"
                ValueChanged="Slider_Changed"/>

        <Label Content="Quote Interval (seconds)"/>
        <Slider x:Name="QuoteSlider"
                Minimum="20"
                Maximum="300"
                SmallChange="5"
                IsSnapToTickEnabled="True"
                TickFrequency="5"
                ValueChanged="Slider_Changed"/>

        <Separator Margin="0,10,0,6"
                   Background="#313244"/>

        <CheckBox x:Name="ShowCatCheck"
                  Content="Show cat mascot"
                  Checked="Toggle_Changed"
                  Unchecked="Toggle_Changed"/>
        <CheckBox x:Name="ShowQuoteCheck"
                  Content="Show anime quote"
                  Checked="Toggle_Changed"
                  Unchecked="Toggle_Changed"/>

        <Separator Margin="0,10,0,6"
                Background="#313244"/>

        <Label Content="COLOR SCHEME"
               FontSize="10"
                FontWeight="SemiBold"
               Foreground="#89B4FA"
                Margin="0,0,0,6"/>
        <WrapPanel x:Name="ThemePanel"
                Margin="0,0,0,4"/>

        <Separator Margin="0,10,0,6"
                Background="#313244"/>

        <Label Content="CAT MASCOT"
               FontSize="10"
                FontWeight="SemiBold"
               Foreground="#89B4FA"
                Margin="0,0,0,4"/>
        <CheckBox x:Name="UseGifCheck"
                  Content="Use custom GIF instead of pixel cat"
                  Checked="Toggle_Changed"
                  Unchecked="Toggle_Changed"/>
        <StackPanel Orientation="Horizontal"
                Margin="0,6,0,0">
            <Button Content="Browse GIF…"
                    Click="BrowseGif_Click"
                    Padding="8,4"
                    Margin="0,0,8,0"/>
            <TextBlock x:Name="GifPathLabel"
                       VerticalAlignment="Center"
                       FontSize="10"
                       Foreground="#A6ADC8"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="200"/>
        </StackPanel>

        <Separator Margin="0,10,0,6"
                   Background="#313244"/>

        <Label Content="Position X"/>
        <Slider x:Name="PosXSlider"
                Minimum="0"
                SmallChange="1"
                IsSnapToTickEnabled="False"
                ValueChanged="Slider_Changed"/>

        <Label Content="Position Y"/>
        <Slider x:Name="PosYSlider"
                Minimum="0"
                SmallChange="1"
                IsSnapToTickEnabled="False"
                ValueChanged="Slider_Changed"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    Click="Close_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Click="Save_Click"
                    Background="#89B4FA"
                    Foreground="#1E1E2E"/>
        </StackPanel>
    </StackPanel>
</Window>
