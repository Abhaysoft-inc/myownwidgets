<Window x:Class="GifWidget.AppearanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GIF Widget – Appearance"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <Border Background="#F2181828"
            CornerRadius="12"
            Padding="20">
        <StackPanel>

            <!-- Title bar -->
            <Grid Margin="0 0 0 20">
                <TextBlock Text="Appearance"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#E0E0F0"/>
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Width="26"
                        Height="26"
                        FontSize="11"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#88AAAACC"
                        Cursor="Hand"
                        Click="CancelBtn_Click"/>
            </Grid>

            <!-- Opacity -->
            <TextBlock Text="OPACITY"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#55667788"
                       Margin="0 0 0 8"/>
            <Grid Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="OpacitySlider"
                        Grid.Column="0"
                        Minimum="0.1"
                        Maximum="1.0"
                        TickFrequency="0.05"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="OpacitySlider_ValueChanged"/>
                <TextBlock x:Name="OpacityLabel"
                           Grid.Column="1"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Size -->
            <TextBlock Text="SIZE  (width px)"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#55667788"
                       Margin="0 0 0 8"/>
            <Grid Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SizeSlider"
                        Grid.Column="0"
                        Minimum="50"
                        Maximum="800"
                        TickFrequency="10"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="SizeSlider_ValueChanged"/>
                <TextBlock x:Name="SizeLabel"
                           Grid.Column="1"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Corner radius -->
            <TextBlock Text="CORNER RADIUS"
                       FontFamily="Segoe UI"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#55667788"
                       Margin="0 0 0 8"/>
            <Grid Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="RadiusSlider"
                        Grid.Column="0"
                        Minimum="0"
                        Maximum="50"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="RadiusSlider_ValueChanged"/>
                <TextBlock x:Name="RadiusLabel"
                           Grid.Column="1"
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Border toggle -->
            <CheckBox x:Name="BorderCheck"
                      Content="Show border"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      Foreground="#AAAACC"
                      Margin="0 0 0 24"
                      Checked="BorderCheck_Changed"
                      Unchecked="BorderCheck_Changed"/>

            <!-- Position -->
            <TextBlock Text="POSITION"
                       FontFamily="Segoe UI"
                    FontSize="10"
                    FontWeight="SemiBold"
                       Foreground="#55667788"
                    Margin="0 0 0 8"/>

            <!-- X -->
            <Grid Margin="0 0 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                        Text="X"
                           FontFamily="Segoe UI"
                        FontSize="11"
                           Foreground="#88AAAACC"
                        VerticalAlignment="Center"/>
                <Slider x:Name="PosXSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="3840"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="PosXSlider_ValueChanged"/>
                <TextBlock x:Name="PosXLabel"
                           Grid.Column="2"
                           FontFamily="Segoe UI"
                        FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Y -->
            <Grid Margin="0 0 0 24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="52"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                        Text="Y"
                           FontFamily="Segoe UI"
                        FontSize="11"
                           Foreground="#88AAAACC"
                        VerticalAlignment="Center"/>
                <Slider x:Name="PosYSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="2160"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="PosYSlider_ValueChanged"/>
                <TextBlock x:Name="PosYLabel"
                           Grid.Column="2"
                           FontFamily="Segoe UI"
                        FontSize="12"
                           Foreground="#88AAAACC"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Content="Cancel"
                        Padding="0 10"
                        Background="#2A2A3E"
                        Foreground="#8888AA"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        Cursor="Hand"
                        Click="CancelBtn_Click"/>
                <Button Grid.Column="2"
                        Content="Apply"
                        Padding="0 10"
                        Background="#334488"
                        Foreground="#C0D8FF"
                        BorderThickness="0"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="ApplyBtn_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
